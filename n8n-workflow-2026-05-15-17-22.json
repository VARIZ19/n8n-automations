<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Variz — Automation Engineer</title>
<meta name="description" content="n8n workflows, AI automation & Chrome extensions."/>
<meta name="twitter:creator" content="@varizsinghxh"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#000;--bg2:#111;--bg3:#1c1c1c;--text:#fff;--muted:#888;--border:#222;--accent:#00d084;--blue:#2563eb;--pill:#1c1c1c}
[data-theme=light]{--bg:#fff;--bg2:#f5f5f5;--bg3:#eaeaea;--text:#000;--muted:#555;--border:#e0e0e0;--pill:#ececec}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;max-width:480px;margin:0 auto;padding:0 20px 80px;-webkit-font-smoothing:antialiased;transition:background .2s,color .2s}
.theme-btn{position:fixed;bottom:24px;right:20px;width:38px;height:38px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:17px;z-index:99;transition:background .2s}
.theme-btn:hover{background:var(--bg2)}
.profile{padding:36px 0 0}
.avatar{width:86px;height:86px;border-radius:18px;overflow:hidden;margin-bottom:16px;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:700;color:var(--accent)}
.avatar img{width:100%;height:100%;object-fit:cover;object-position:center 15%;display:block}
.pname{font-size:1.3rem;font-weight:700;display:flex;align-items:center;gap:5px;margin-bottom:3px}
.prole{font-size:.92rem;color:var(--muted);margin-bottom:12px}
.pbio{font-size:.88rem;line-height:1.65;color:var(--muted);margin-bottom:18px}
.phighlight{background:rgba(0,208,132,.13);color:var(--accent);padding:1px 5px;border-radius:4px;font-weight:500}
.btn-row{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap}
.btn-outline{display:inline-flex;align-items:center;gap:5px;padding:8px 15px;border-radius:99px;background:var(--pill);border:1px solid var(--border);color:var(--text);font-size:.82rem;font-weight:500;text-decoration:none;cursor:pointer;transition:background .15s}
.btn-outline:hover{background:var(--bg3)}
.btn-blue{display:inline-flex;align-items:center;gap:5px;padding:8px 15px;border-radius:7px;background:var(--blue);border:none;color:#fff;font-size:.82rem;font-weight:600;text-decoration:none;cursor:pointer;transition:opacity .15s}
.btn-blue:hover{opacity:.85}
.social-row{display:flex;gap:7px;flex-wrap:wrap;padding-bottom:26px;border-bottom:1px solid var(--border)}
.spill{display:inline-flex;align-items:center;padding:7px 13px;border-radius:99px;background:var(--pill);border:1px solid var(--border);color:var(--text);font-size:.8rem;font-weight:500;text-decoration:none;transition:background .15s}
.spill:hover{background:var(--bg3)}
.tabs{display:flex;gap:22px;margin:26px 0 18px;border-bottom:1px solid var(--border)}
.tab{font-size:.93rem;font-weight:500;color:var(--muted);padding-bottom:11px;cursor:pointer;border:none;border-bottom:2px solid transparent;margin-bottom:-1px;background:none;transition:color .2s,border-color .2s}
.tab.on{color:var(--text);border-bottom-color:var(--text)}
.tc{display:none}
.tc.on{display:block}
.pcard{margin-bottom:30px}
.pthumb{width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;background:var(--bg2);margin-bottom:12px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border)}
.pthumb-inner{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px;gap:8px}
.fv{display:flex;align-items:center;gap:5px;flex-wrap:wrap;justify-content:center}
.fn{font-size:.62rem;padding:3px 7px;border-radius:5px;background:var(--bg3);border:1px solid var(--border);color:var(--muted);font-family:monospace;white-space:nowrap}
.fa{color:var(--accent);font-size:.65rem}
.fstatus{font-size:.68rem;color:var(--accent);font-weight:600;display:flex;align-items:center;gap:4px}
.pname{font-size:1.05rem;font-weight:700;display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:5px}
.badge{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:99px;font-size:.68rem;font-weight:600}
.b-live{background:rgba(0,208,132,.12);color:var(--accent)}
.b-blue{background:rgba(37,99,235,.12);color:#60a5fa}
.b-purple{background:rgba(139,92,246,.12);color:#a78bfa}
.bdot{width:5px;height:5px;border-radius:50%;background:currentColor;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.35}}
.plinks{display:flex;gap:14px;font-size:.88rem;font-weight:600;margin-bottom:7px}
.plinks a{color:var(--text);text-decoration:none}
.plinks a:hover{color:var(--accent)}
.pdesc{font-size:.85rem;color:var(--muted);line-height:1.6}
.cbox{background:var(--bg2);border:1px solid var(--border);border-radius:18px;padding:18px;margin:28px 0}
.chead{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.ctitle{font-size:.95rem;font-weight:700}
.clink{font-size:.8rem;color:var(--muted);text-decoration:none}
.clink:hover{color:var(--accent)}
.cgrid{overflow-x:auto;margin-bottom:12px}
.cfoot{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.ccount{font-size:.82rem;font-weight:600}
.ccount span{color:var(--muted);font-weight:400}
.legend{display:flex;align-items:center;gap:4px;font-size:.7rem;color:var(--muted)}
.lc{display:flex;gap:3px}
.stacks{margin-top:28px}
.st{font-size:1.2rem;font-weight:700;margin-bottom:18px}
.sg{margin-bottom:16px}
.sl{font-size:.92rem;font-weight:700;display:flex;align-items:center;gap:6px;margin-bottom:3px}
.si{font-size:.85rem;color:var(--muted);line-height:1.7}
.foot{display:flex;align-items:center;justify-content:space-between;padding-top:26px;border-top:1px solid var(--border);margin-top:36px}
.footxt{font-size:.78rem;color:var(--muted)}
</style>
</head>
