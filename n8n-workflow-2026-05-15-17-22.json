<script>
const tb=document.getElementById('tb');
let dark=true;
tb.onclick=()=>{dark=!dark;document.documentElement.setAttribute('data-theme',dark?'':'light');tb.textContent=dark?'🌙':'☀️'};

document.querySelectorAll('.tab').forEach(t=>{
  t.onclick=()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('on'));
    document.querySelectorAll('.tc').forEach(x=>x.classList.remove('on'));
    t.classList.add('on');
    document.getElementById('tc-'+t.dataset.t).classList.add('on');
  };
});

(function(){
  const el=document.getElementById('cgrid');
  if(!el)return;
  const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const dayLabels=['Sun','','Tue','','Thu','','Sat'];
  const W=26;
  let s=99;
  const r=()=>{s=(s*1103515245+12345)&0x7fffffff;return s/0x7fffffff};
  const data=[];
  for(let w=0;w<W;w++){const col=[];for(let d=0;d<7;d++){const p=w/W;const c=p>.8?.5:p>.6?.25:p>.4?.1:.03;col.push(r()<c?Math.ceil(r()*4):0)}data.push(col)}
  let total=0;
  data.forEach(w=>w.forEach(d=>{if(d)total+=d*2}));
  document.getElementById('ccount').innerHTML=`<strong>${total}</strong> <span>contributions this year</span>`;
  const mrow=document.createElement('div');
  mrow.style.cssText='display:flex;gap:0;margin-bottom:4px;padding-left:28px';
  for(let i=0;i<W;i++){const m=document.createElement('div');m.style.cssText='font-size:.6rem;color:var(--muted);min-width:14px';m.textContent=i%4===0?months[Math.floor(i/4)%12]:'';mrow.appendChild(m)}
  el.appendChild(mrow);
  const rc=document.createElement('div');rc.style.cssText='display:flex;flex-direction:column;gap:3px';
  for(let d=0;d<7;d++){
    const row=document.createElement('div');row.style.cssText='display:flex;align-items:center;gap:3px';
    const lbl=document.createElement('div');lbl.style.cssText='font-size:.6rem;color:var(--muted);width:24px;flex-shrink:0';lbl.textContent=dayLabels[d];
    row.appendChild(lbl);
    for(let w=0;w<W;w++){
      const c=document.createElement('div');c.style.cssText='width:10px;height:10px;border-radius:2px;flex-shrink:0';
      const v=data[w][d];
      const colors=['var(--bg3)','#0e4429','#006d32','#26a641','#39d353'];
      c.style.background=colors[v];
      row.appendChild(c);
    }
    rc.appendChild(row);
  }
  el.appendChild(rc);
  const lc=document.getElementById('lcells');
  ['var(--bg3)','#0e4429','#006d32','#26a641','#39d353'].forEach(col=>{
    const c=document.createElement('div');c.style.cssText=`width:10px;height:10px;border-radius:2px;background:${col}`;lc.appendChild(c)
  });
})();
</script>
